        <mxCell id="step3" value="3. Git commit/push&lt;br&gt;リポジトリ更新" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=12;fontStyle=1" vertex="1" parent="1">
