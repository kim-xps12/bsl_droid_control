          <mxGeometry x="560" y="525" width="220" height="25" as="geometry" />
        </mxCell>

        <!-- Topics examples -->
        <mxCell id="topics-flow" value="/robot_state, /joint_states, /imu/data, /tf →" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="700" y="555" width="200" height="20" as="geometry" />
