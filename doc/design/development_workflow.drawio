        <!-- SSH commands -->
        <mxCell id="ssh-box" value="SSH経由でも操作可能&lt;br&gt;&lt;br&gt;&lt;font face=&quot;monospace&quot; style=&quot;font-size: 9px;&quot;&gt;ssh jetson&lt;br&gt;cd ~/ros2_ws&lt;br&gt;git pull&lt;br&gt;colcon build&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;dashed=1" vertex="1" parent="1">
          <mxGeometry x="940" y="130" width="150" height="90" as="geometry" />
        </mxCell>

        <!-- Visualization Section -->
        <mxCell id="viz-section" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="400" width="1200" height="200" as="geometry" />
        </mxCell>
        
        <mxCell id="viz-title" value="📊 可視化・デバッグ (MacBook ← ROS 2 DDS → Jetson)" style="text;html=1;strokeColor=none;fillColor=#e8f5e9;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
