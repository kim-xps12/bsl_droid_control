        <mxCell id="step10" value="10. teleop&lt;br&gt;手動操作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#4caf50;fontSize=12;" vertex="1" parent="1">
