        <mxCell id="step1" value="1. コード編集&lt;br&gt;VS Code / Editor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;fontSize=12;fontStyle=1" vertex="1" parent="1">
