        </mxCell>
        
        <mxCell id="step8" value="8. Plotjuggler&lt;br&gt;データプロット" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#4caf50;fontSize=12;" vertex="1" parent="1">
