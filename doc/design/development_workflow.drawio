        <mxCell id="step7" value="7. RViz2&lt;br&gt;ロボット可視化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#4caf50;fontSize=12;fontStyle=1" vertex="1" parent="1">
