        </mxCell>

        <mxCell id="cmd-mac" value="MacBook側:&lt;br&gt;&lt;br&gt;&lt;font face=&quot;monospace&quot; style=&quot;font-size: 10px;&quot;&gt;# ローカルビルド&lt;br&gt;cd ~/ros2_ws &amp;amp;&amp;amp; colcon build&lt;br&gt;&lt;br&gt;# Jetsonにログイン&lt;br&gt;ssh jetson&lt;br&gt;&lt;br&gt;# 可視化起動&lt;br&gt;ros2 launch biped_bringup visualization.launch.py&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=#e3f2fd;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;strokeColor=#1976d2" vertex="1" parent="1">
          <mxGeometry x="120" y="670" width="320" height="100" as="geometry" />
        </mxCell>

        <mxCell id="cmd-jetson" value="Jetson側:&lt;br&gt;&lt;br&gt;&lt;font face=&quot;monospace&quot; style=&quot;font-size: 10px;&quot;&gt;# コード更新 &amp;amp; ビルド&lt;br&gt;cd ~/ros2_ws &amp;amp;&amp;amp; git pull &amp;amp;&amp;amp; colcon build&lt;br&gt;&lt;br&gt;# ロボット起動&lt;br&gt;ros2 launch robstride_hardware robstride_control.launch.py&lt;br&gt;&lt;br&gt;# 全システム起動&lt;br&gt;ros2 launch biped_bringup robot_bringup.launch.py&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=#fff9c4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;strokeColor=#fbc02d" vertex="1" parent="1">
          <mxGeometry x="460" y="670" width="380" height="100" as="geometry" />
        </mxCell>

        <mxCell id="cmd-debug" value="デバッグ:&lt;br&gt;&lt;br&gt;&lt;font face=&quot;monospace&quot; style=&quot;font-size: 10px;&quot;&gt;# トピック確認&lt;br&gt;ros2 topic list&lt;br&gt;ros2 topic echo /robot_state&lt;br&gt;&lt;br&gt;# ノード確認&lt;br&gt;ros2 node list&lt;br&gt;ros2 node info /safety_monitor&lt;br&gt;&lt;br&gt;# ネットワーク疎通&lt;br&gt;ros2 multicast receive/send&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=#e8f5e9;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;strokeColor=#4caf50" vertex="1" parent="1">
