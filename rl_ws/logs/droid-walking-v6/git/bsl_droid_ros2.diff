-        
-        # 最初の接地時に、滞空時間が目標以上なら報酬
-        target_air_time = self.reward_cfg.get("feet_air_time_target", 0.25)
-        rew_air_time = torch.sum(
-            (self.feet_air_time - target_air_time) * self._first_contact.float(), dim=1
