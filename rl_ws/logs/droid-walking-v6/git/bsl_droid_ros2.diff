-                self.feet_air_time = torch.where(contacts, torch.zeros_like(self.feet_air_time), self.feet_air_time)
-                
-                # V5: 足の位置を更新（歩幅計算用）
-                current_feet_pos = self._get_foot_positions()
-                if current_feet_pos is not None:
-                    # 接地時に前回位置を更新
-                    self.last_feet_pos = torch.where(
