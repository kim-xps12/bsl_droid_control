-        contact_threshold = 0.03  # 3cm以下で接地判定
-        link_pos = self.robot.get_links_pos()  # (n_envs, n_links, 3)
-        feet_z = link_pos[:, self.feet_indices, 2]  # (n_envs, n_feet)
-        return feet_z < contact_threshold
-
