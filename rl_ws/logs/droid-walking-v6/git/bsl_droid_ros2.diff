-        # 関節角度を取得（hip_pitch, knee_pitch が主に影響）
-        hip_pitch = leg_joints[:, 2]   # index 2: hip_pitch
-        knee_pitch = leg_joints[:, 3]  # index 3: knee_pitch
-
-        # 順運動学（X-Z平面、股関節からの相対位置）
-        # 大腿の先端（膝の位置）
-        knee_x = self.thigh_length * torch.sin(hip_pitch)
