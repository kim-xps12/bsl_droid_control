-def gs_rand(lower, upper, batch_shape):
-    """一様乱数を生成"""
-    assert lower.shape == upper.shape
-    return (upper - lower) * torch.rand(size=(*batch_shape, *lower.shape), dtype=gs.tc_float, device=gs.device) + lower
