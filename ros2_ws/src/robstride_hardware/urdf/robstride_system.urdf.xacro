<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robstride_robot">
  
  <!-- Minimal robot description -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </visual>
  </link>
  
  <link name="joint1_link">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.05"/>
      </geometry>
    </visual>
  </link>
  
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="joint1_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10.0" velocity="5.0"/>
  </joint>
  
  <!-- ros2_control configuration -->
  <ros2_control name="robstride_system" type="system">
    <hardware>
      <plugin>robstride_hardware/RobStrideHardware</plugin>
      <param name="can_interface">can1</param>
      <param name="motor_id">127</param>
      <param name="kp">1.5</param>
      <param name="kd">0.01</param>
    </hardware>
    
    <joint name="joint1">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
  
</robot>
