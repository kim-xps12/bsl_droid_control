<?xml version="1.0"?>
<robot name="biped_digitigrade_claude_code" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    BD-1風 逆関節（Digitigrade/鳥脚型）二脚ロボット URDF

    特徴:
    - 膝が後方に曲がる逆関節構造（鳥脚型）
    - 片脚5関節 × 2脚（左右対称・鏡像配置）
    - 関節構成: 股関節ヨー, 股関節ロール, 股関節ピッチ, 膝ピッチ, 足首ピッチ
    - 脚は胴体の左右側面から生える
    - 足裏はかまぼこ型（半円柱・X軸方向）でロール安定性を確保
    - 首と顔付き（関節なし）
    - 全高: 約0.85m（人間の腰程度）
    - IMUリンク: 胴体上面中央に配置（強化学習・状態推定用）
  -->

  <!-- ========== 寸法パラメータ ========== -->

  <!-- 胴体（BD-1風：大きめの箱型） -->
  <xacro:property name="body_width" value="0.22" />      <!-- 胴体幅（Y方向） [m] -->
  <xacro:property name="body_depth" value="0.18" />      <!-- 胴体奥行き（X方向） [m] -->
  <xacro:property name="body_height" value="0.24" />     <!-- 胴体高さ（Z方向） [m] -->

  <!-- 首と顔（BD-1風：首は短く、顔は前後に長い） -->
  <xacro:property name="neck_length" value="0.025" />    <!-- 首の長さ（短い） [m] -->
  <xacro:property name="neck_radius" value="0.03" />     <!-- 首の半径 [m] -->
  <xacro:property name="head_width" value="0.18" />      <!-- 顔の幅（Y方向） [m] -->
  <xacro:property name="head_depth" value="0.14" />      <!-- 顔の奥行き（X方向・前後に長い） [m] -->
  <xacro:property name="head_height" value="0.035" />    <!-- 顔の高さ（Z方向・薄い） [m] -->
  <xacro:property name="eye_radius" value="0.022" />     <!-- 目の半径 [m] -->
  <xacro:property name="eye_depth" value="0.012" />      <!-- 目の出っ張り [m] -->
  <xacro:property name="eye_spacing" value="0.055" />    <!-- 目の間隔（中心から左右） [m] -->

  <!-- 脚部（BD-1風：短めでずんぐり） -->
  <xacro:property name="hip_y_offset" value="0.11" />    <!-- 胴体中心から股関節までのY距離 [m] -->
  <xacro:property name="hip_x_offset" value="-0.01" />   <!-- 胴体中心から股関節までのX距離（やや後方） [m] -->
  <xacro:property name="hip_yaw_length" value="0.025" /> <!-- ヨー軸リンク長 [m] -->
  <xacro:property name="hip_roll_length" value="0.02" /> <!-- ロール軸リンク長 [m] -->
  <xacro:property name="thigh_length" value="0.10" />    <!-- 大腿部長さ（短め） [m] -->
  <xacro:property name="shank_length" value="0.12" />    <!-- 下腿部長さ（短め） [m] -->

  <!-- 足部 -->
  <xacro:property name="foot_length" value="0.10" />     <!-- 足の全長（X方向） [m] -->
  <xacro:property name="foot_width" value="0.05" />      <!-- 足の幅（Y方向） [m] -->
  <xacro:property name="foot_radius" value="0.025" />    <!-- かまぼこ型足裏の半径 [m] -->
  <xacro:property name="ankle_x_offset" value="0.025" /> <!-- 足首から足後端までの距離 [m] -->

  <!-- リンク太さ -->
  <xacro:property name="thigh_radius" value="0.022" />
  <xacro:property name="shank_radius" value="0.018" />
  <xacro:property name="joint_radius" value="0.025" />

  <!-- pi は xacro の組み込み定数を使用 -->

  <!-- ========== マテリアル定義 ========== -->

  <material name="body_white">
    <color rgba="0.95 0.95 0.92 1.0"/>
  </material>

  <material name="body_accent">
    <color rgba="0.2 0.45 0.7 1.0"/>
  </material>

  <material name="leg_gray">
    <color rgba="0.25 0.25 0.28 1.0"/>
  </material>

  <material name="joint_dark">
    <color rgba="0.12 0.12 0.15 1.0"/>
  </material>

  <material name="foot_blue">
    <color rgba="0.22 0.42 0.6 1.0"/>
  </material>

  <material name="eye_white">
    <color rgba="0.98 0.98 0.95 1.0"/>
  </material>

  <material name="eye_lens">
    <color rgba="0.08 0.08 0.1 1.0"/>
  </material>

  <material name="head_dark">
    <color rgba="0.1 0.1 0.12 1.0"/>
  </material>

  <!-- ========== Base Link (胴体) ========== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${body_depth} ${body_width} ${body_height}"/>
      </geometry>
      <material name="body_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${body_depth} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.035" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <!-- ========== IMU Link ========== -->
  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="joint_dark"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ========== 首 (Neck) ========== -->
  <link name="neck_link">
    <visual>
      <origin xyz="0 0 ${neck_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${neck_radius}" length="${neck_length}"/>
      </geometry>
      <material name="leg_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${neck_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${neck_radius}" length="${neck_length}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 ${neck_length/2}" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="neck_joint" type="fixed">
    <parent link="base_link"/>
    <child link="neck_link"/>
    <!-- 首は胴体の前方上面から生える -->
    <origin xyz="${body_depth/2 - 0.04} 0 ${body_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ========== 顔 (Head) ========== -->
  <link name="head_link">
    <visual>
      <origin xyz="${head_depth/2 - 0.02} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${head_depth} ${head_width} ${head_height}"/>
      </geometry>
      <material name="head_dark"/>
    </visual>
    <collision>
      <origin xyz="${head_depth/2 - 0.02} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${head_depth} ${head_width} ${head_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="${head_depth/2 - 0.02} 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="neck_link"/>
    <child link="head_link"/>
    <!-- 顔は首の上に配置 -->
    <origin xyz="0 0 ${neck_length + head_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ========== 左目 (Left Eye) ========== -->
  <link name="left_eye_link">
    <visual>
      <origin xyz="${eye_depth/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${eye_radius}" length="${eye_depth}"/>
      </geometry>
      <material name="eye_white"/>
    </visual>
    <visual>
      <!-- 瞳（レンズ） -->
      <origin xyz="${eye_depth + 0.003} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${eye_radius * 0.55}" length="0.006"/>
      </geometry>
      <material name="eye_lens"/>
    </visual>
    <inertial>
      <mass value="0.015"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="left_eye_joint" type="fixed">
    <parent link="head_link"/>
    <child link="left_eye_link"/>
    <origin xyz="${head_depth - 0.02} ${eye_spacing} 0" rpy="0 0 0"/>
  </joint>

  <!-- ========== 右目 (Right Eye) ========== -->
  <link name="right_eye_link">
    <visual>
      <origin xyz="${eye_depth/2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${eye_radius}" length="${eye_depth}"/>
      </geometry>
      <material name="eye_white"/>
    </visual>
    <visual>
      <!-- 瞳（レンズ） -->
      <origin xyz="${eye_depth + 0.003} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry>
        <cylinder radius="${eye_radius * 0.55}" length="0.006"/>
      </geometry>
      <material name="eye_lens"/>
    </visual>
    <inertial>
      <mass value="0.015"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="right_eye_joint" type="fixed">
    <parent link="head_link"/>
    <child link="right_eye_link"/>
    <origin xyz="${head_depth - 0.02} ${-eye_spacing} 0" rpy="0 0 0"/>
  </joint>

  <!-- ========== 脚マクロ定義 ========== -->
  <xacro:macro name="leg" params="side reflect">

    <!--
      関節構成（5軸/脚）:
      - 股関節ヨー (Hip Yaw): Z軸回転
      - 股関節ロール (Hip Roll): X軸回転
      - 股関節ピッチ (Hip Pitch): Y軸回転
      - 膝ピッチ (Knee Pitch): Y軸回転 - 逆関節（後方に曲がる）
      - 足首ピッチ (Ankle Pitch): Y軸回転

      左脚 (side=left, reflect=1):  j11, j12, j13, j14, j15
      右脚 (side=right, reflect=-1): j21, j22, j23, j24, j25
    -->

    <!-- Hip Yaw Joint (股関節ヨー) -->
    <joint name="${side}_hip_yaw_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${side}_hip_yaw_link"/>
      <!-- 脚は胴体の側面から生える -->
      <origin xyz="${hip_x_offset} ${reflect * hip_y_offset} 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-45 * pi / 180}" upper="${45 * pi / 180}" effort="50" velocity="5"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="${side}_hip_yaw_link">
      <visual>
        <origin xyz="0 ${reflect * hip_yaw_length/2} 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${joint_radius}" length="${hip_yaw_length}"/>
        </geometry>
        <material name="joint_dark"/>
      </visual>
      <inertial>
        <mass value="0.25"/>
        <origin xyz="0 ${reflect * hip_yaw_length/2} 0" rpy="0 0 0"/>
        <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0008"/>
      </inertial>
    </link>

    <!-- Hip Roll Joint (股関節ロール) -->
    <joint name="${side}_hip_roll_joint" type="revolute">
      <parent link="${side}_hip_yaw_link"/>
      <child link="${side}_hip_roll_link"/>
      <origin xyz="0 ${reflect * hip_yaw_length} 0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="${-25 * pi / 180}" upper="${25 * pi / 180}" effort="50" velocity="5"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="${side}_hip_roll_link">
      <visual>
        <origin xyz="0 0 ${-hip_roll_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${joint_radius * 0.8}" length="${hip_roll_length}"/>
        </geometry>
        <material name="joint_dark"/>
      </visual>
      <inertial>
        <mass value="0.15"/>
        <origin xyz="0 0 ${-hip_roll_length/2}" rpy="0 0 0"/>
        <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0004"/>
      </inertial>
    </link>

    <!-- Hip Pitch Joint (股関節ピッチ) -->
    <joint name="${side}_hip_pitch_joint" type="revolute">
      <parent link="${side}_hip_roll_link"/>
      <child link="${side}_thigh_link"/>
      <origin xyz="0 0 ${-hip_roll_length}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-90 * pi / 180}" upper="${90 * pi / 180}" effort="100" velocity="10"/>
      <dynamics damping="0.2" friction="0.15"/>
    </joint>

    <link name="${side}_thigh_link">
      <visual>
        <origin xyz="0 0 ${-thigh_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${thigh_radius}" length="${thigh_length}"/>
        </geometry>
        <material name="leg_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-thigh_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${thigh_radius}" length="${thigh_length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.6"/>
        <origin xyz="0 0 ${-thigh_length/2}" rpy="0 0 0"/>
        <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.0005"/>
      </inertial>
    </link>

    <!-- Knee Pitch Joint (膝ピッチ) - 逆関節：後方に曲がる（正の角度で後方へ） -->
    <joint name="${side}_knee_pitch_joint" type="revolute">
      <parent link="${side}_thigh_link"/>
      <child link="${side}_shank_link"/>
      <origin xyz="0 0 ${-thigh_length}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <!-- 逆関節: 正の角度で後方に曲がる（鳥脚型） -->
      <limit lower="${0 * pi / 180}" upper="${120 * pi / 180}" effort="100" velocity="10"/>
      <dynamics damping="0.2" friction="0.15"/>
    </joint>

    <link name="${side}_shank_link">
      <visual>
        <origin xyz="0 0 ${-shank_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${shank_radius}" length="${shank_length}"/>
        </geometry>
        <material name="leg_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-shank_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${shank_radius}" length="${shank_length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.4"/>
        <origin xyz="0 0 ${-shank_length/2}" rpy="0 0 0"/>
        <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0003"/>
      </inertial>
    </link>

    <!-- Ankle Pitch Joint (足首ピッチ) -->
    <joint name="${side}_ankle_pitch_joint" type="revolute">
      <parent link="${side}_shank_link"/>
      <child link="${side}_foot_link"/>
      <origin xyz="0 0 ${-shank_length}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-60 * pi / 180}" upper="${60 * pi / 180}" effort="50" velocity="10"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="${side}_foot_link">
      <!--
        足首は足の後端から少し前方にオフセット
        足裏はかまぼこ型（半円柱・X軸方向に配置）で受動的なロール安定性を提供
        正面から見て半円になるよう、円柱をX軸方向に配置
      -->
      <!-- メイン足部（上部構造） -->
      <visual>
        <origin xyz="${foot_length/2 - ankle_x_offset} 0 ${-foot_radius/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${foot_length} ${foot_width} ${foot_radius}"/>
        </geometry>
        <material name="foot_blue"/>
      </visual>
      <!-- かまぼこ型足裏（半円柱・X軸方向に配置で正面から見て半円） -->
      <visual>
        <origin xyz="${foot_length/2 - ankle_x_offset} 0 ${-foot_radius}" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${foot_radius}" length="${foot_length}"/>
        </geometry>
        <material name="foot_blue"/>
      </visual>
      <collision>
        <!-- 足裏の接地面として半円柱を使用（X軸方向） -->
        <origin xyz="${foot_length/2 - ankle_x_offset} 0 ${-foot_radius}" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${foot_radius}" length="${foot_length}"/>
        </geometry>
      </collision>
      <collision>
        <!-- 上部構造の衝突形状 -->
        <origin xyz="${foot_length/2 - ankle_x_offset} 0 ${-foot_radius/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${foot_length} ${foot_width} ${foot_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <origin xyz="${foot_length/2 - ankle_x_offset} 0 ${-foot_radius}" rpy="0 0 0"/>
        <inertia ixx="0.0006" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0006"/>
      </inertial>
    </link>

  </xacro:macro>

  <!-- ========== 左右の脚を生成 ========== -->
  <xacro:leg side="left" reflect="1"/>
  <xacro:leg side="right" reflect="-1"/>

</robot>
